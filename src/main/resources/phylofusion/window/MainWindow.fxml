<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.input.*?>
<?import javafx.scene.layout.*?>
<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/23.0.1"
            xmlns:fx="http://javafx.com/fxml/1" fx:controller="phylofusion.window.MainWindowController">
    <children>
        <BorderPane AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0"
                    AnchorPane.topAnchor="0.0">
            <center>
                <SplitPane dividerPositions="0.29797979797979796" prefHeight="160.0" prefWidth="200.0"
                           BorderPane.alignment="CENTER">
                    <items>
                        <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="160.0" prefWidth="100.0">
                            <children>
                                <VBox AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
                                      AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                                    <children>
                                        <TableView fx:id="treeTable" editable="true" VBox.vgrow="ALWAYS">
                                            <columns>
                                                <TableColumn fx:id="treeColumn" maxWidth="400.0" minWidth="50.0"
                                                             prefWidth="-1.0" text="Tree"/>
                                                <TableColumn fx:id="useColumn" minWidth="50.0" prefWidth="-1.0"
                                                             text="Use"/>
                                                <TableColumn fx:id="showColumn" minWidth="50.0" prefWidth="-1.0"
                                                             text="Show"/>
                                            </columns>
                                        </TableView>
                                        <GridPane hgap="10.0" vgap="2.0" VBox.vgrow="NEVER">
                                            <columnConstraints>
                                                <ColumnConstraints hgrow="NEVER" minWidth="-Infinity"/>
                                                <ColumnConstraints halignment="LEFT" hgrow="ALWAYS"/>
                                            </columnConstraints>
                                            <rowConstraints>
                                                <RowConstraints vgrow="SOMETIMES"/>
                                                <RowConstraints vgrow="SOMETIMES"/>
                                            </rowConstraints>
                                            <children>
                                                <Label text="Min confidence:"/>
                                                <TextField fx:id="confidenceTextField" maxWidth="100.0"
                                                           GridPane.columnIndex="1">
                                                    <tooltip>
                                                        <Tooltip text="Minimum  confidence for input branch filtering"/>
                                                    </tooltip>
                                                </TextField>
                                                <Label fx:id="confidenceLabel" style="-fx-text-fill: lightgray;"
                                                       text="Label" GridPane.rowIndex="1"/>
                                                <HBox alignment="CENTER_RIGHT" GridPane.columnIndex="1"
                                                      GridPane.rowIndex="1">
                                                    <children>
                                                        <Button fx:id="runButton" mnemonicParsing="false" text="Run"/>
                                                    </children>
                                                </HBox>
                                            </children>
                                            <VBox.margin>
                                                <Insets bottom="4.0" left="4.0" right="4.0" top="4.0"/>
                                            </VBox.margin>
                                        </GridPane>
                                    </children>
                                    <padding>
                                        <Insets left="4.0"/>
                                    </padding>
                                </VBox>

                            </children>
                        </AnchorPane>
                        <AnchorPane fx:id="centerAnchorPane" minHeight="0.0" minWidth="0.0" prefHeight="160.0"
                                    prefWidth="100.0">
                            <children>
                                <BorderPane AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
                                            AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                                    <center>
                                        <StackPane fx:id="centerPane"/>
                                    </center>
                                    <top>
                                        <ToolBar minHeight="30.0" BorderPane.alignment="CENTER"/>
                                    </top>
                                </BorderPane>
                            </children>
                        </AnchorPane>
                    </items>
                </SplitPane>
            </center>
            <top>
                <VBox BorderPane.alignment="CENTER">
                    <children>
                        <MenuBar fx:id="menuBar">
                            <menus>
                                <Menu fx:id="fileMenu" mnemonicParsing="false" text="File">
                                    <items>
                                        <MenuItem fx:id="newMenuItem" mnemonicParsing="false" text="New...">
                                            <accelerator>
                                                <KeyCodeCombination alt="UP" code="N" control="UP" meta="DOWN"
                                                                    shift="UP" shortcut="UP"/>
                                            </accelerator>
                                        </MenuItem>
                                        <SeparatorMenuItem mnemonicParsing="false"/>
                                        <MenuItem fx:id="openMenuItem" mnemonicParsing="false" text="Open...">
                                            <accelerator>
                                                <KeyCodeCombination alt="UP" code="O" control="UP" meta="DOWN"
                                                                    shift="UP" shortcut="UP"/>
                                            </accelerator>
                                        </MenuItem>
                                        <Menu fx:id="recentFilesMenu" mnemonicParsing="false" text="Recent"/>

                                        <SeparatorMenuItem mnemonicParsing="false"/>
                                        <Menu fx:id="exportMenu" mnemonicParsing="false" text="Export">
                                            <items>
                                                <MenuItem fx:id="exportImageMenuItem" mnemonicParsing="false"
                                                          text="Image..."/>
                                            </items>
                                            <MenuItem fx:id="exportNewickMenuItem" mnemonicParsing="false"
                                                      text="Newick..."/>
                                        </Menu>
                                        <SeparatorMenuItem mnemonicParsing="false"/>
                                        <MenuItem fx:id="saveMenuItem" mnemonicParsing="false" text="Save...">
                                            <accelerator>
                                                <KeyCodeCombination alt="UP" code="S" control="UP" meta="DOWN"
                                                                    shift="UP" shortcut="UP"/>
                                            </accelerator>
                                        </MenuItem>
                                        <SeparatorMenuItem mnemonicParsing="false"/>
                                        <MenuItem fx:id="pageSetupMenuItem" mnemonicParsing="false"
                                                  text="Page Setup..."/>
                                        <MenuItem fx:id="printMenuItem" mnemonicParsing="false" text="Print...">
                                            <accelerator>
                                                <KeyCodeCombination alt="UP" code="P" control="UP" meta="DOWN"
                                                                    shift="DOWN" shortcut="UP"/>
                                            </accelerator>
                                        </MenuItem>
                                        <SeparatorMenuItem mnemonicParsing="false"/>
                                        <MenuItem fx:id="closeMenuItem" mnemonicParsing="false" text="Close">
                                            <accelerator>
                                                <KeyCodeCombination alt="UP" code="W" control="UP" meta="DOWN"
                                                                    shift="UP" shortcut="UP"/>
                                            </accelerator>
                                        </MenuItem>
                                        <MenuItem fx:id="quitMenuItem" mnemonicParsing="false" text="Quit">
                                            <accelerator>
                                                <KeyCodeCombination alt="UP" code="Q" control="UP" meta="DOWN"
                                                                    shift="UP" shortcut="UP"/>
                                            </accelerator>
                                        </MenuItem>
                                    </items>
                                </Menu>
                                <Menu fx:id="editMenu" mnemonicParsing="false" text="Edit">
                                    <items>
                                        <MenuItem fx:id="undoMenuItem" mnemonicParsing="false" text="Undo">
                                            <accelerator>
                                                <KeyCodeCombination alt="UP" code="Z" control="UP" meta="DOWN"
                                                                    shift="UP" shortcut="UP"/>
                                            </accelerator>
                                        </MenuItem>
                                        <MenuItem fx:id="redoMenuItem" mnemonicParsing="false" text="Redo">
                                            <accelerator>
                                                <KeyCodeCombination alt="UP" code="Z" control="UP" meta="DOWN"
                                                                    shift="DOWN" shortcut="UP"/>
                                            </accelerator>
                                        </MenuItem>
                                        <SeparatorMenuItem mnemonicParsing="false"/>
                                        <MenuItem fx:id="cutMenuItem" mnemonicParsing="false" text="Cut">
                                            <accelerator>
                                                <KeyCodeCombination alt="UP" code="X" control="UP" meta="DOWN"
                                                                    shift="UP" shortcut="UP"/>
                                            </accelerator>
                                        </MenuItem>
                                        <MenuItem fx:id="copyMenuItem" mnemonicParsing="false" text="Copy">
                                            <accelerator>
                                                <KeyCodeCombination alt="UP" code="C" control="UP" meta="DOWN"
                                                                    shift="UP" shortcut="UP"/>
                                            </accelerator>
                                        </MenuItem>
                                        <MenuItem fx:id="copyImageMenuItem" mnemonicParsing="false" text="Copy Image">
                                            <accelerator>
                                                <KeyCodeCombination alt="UP" code="C" control="UP" meta="DOWN"
                                                                    shift="DOWN" shortcut="UP"/>
                                            </accelerator>
                                        </MenuItem>
                                        <MenuItem fx:id="pasteMenuItem" mnemonicParsing="false" text="Paste">
                                            <accelerator>
                                                <KeyCodeCombination alt="UP" code="V" control="UP" meta="DOWN"
                                                                    shift="UP" shortcut="UP"/>
                                            </accelerator>
                                        </MenuItem>
                                        <MenuItem fx:id="deleteMenuItem" mnemonicParsing="false" text="Delete">
                                            <accelerator>
                                                <KeyCodeCombination alt="UP" code="BACK_SPACE" control="UP" meta="DOWN"
                                                                    shift="UP" shortcut="UP"/>
                                            </accelerator>
                                        </MenuItem>
                                        <SeparatorMenuItem mnemonicParsing="false"/>
                                        <MenuItem fx:id="clearMenuItem" mnemonicParsing="false" text="Clear">
                                        </MenuItem>
                                        <SeparatorMenuItem mnemonicParsing="false"/>

                                        <SeparatorMenuItem mnemonicParsing="false"/>
                                        <MenuItem fx:id="findMenuItem" mnemonicParsing="false" text="Find...">
                                            <accelerator>
                                                <KeyCodeCombination alt="UP" code="F" control="UP" meta="DOWN"
                                                                    shift="UP" shortcut="UP"/>
                                            </accelerator>
                                        </MenuItem>
                                        <MenuItem fx:id="findAgainMenuItem" mnemonicParsing="false" text="Find Again">
                                            <accelerator>
                                                <KeyCodeCombination alt="UP" code="G" control="UP" meta="DOWN"
                                                                    shift="UP" shortcut="UP"/>
                                            </accelerator>
                                        </MenuItem>
                                        <SeparatorMenuItem mnemonicParsing="false"/>
                                        <MenuItem fx:id="addLSAEdgeMenuItem" mnemonicParsing="false"
                                                  text="Add LSA Edges"/>

                                    </items>
                                </Menu>
                                <Menu fx:id="treesMenu" mnemonicParsing="false" text="Run">
                                    <items>
                                        <MenuItem fx:id="useAllMenuItem" mnemonicParsing="false"
                                                  text="Use All (Selected) Trees"/>
                                        <MenuItem fx:id="useNoneMenuItem" mnemonicParsing="false"
                                                  text="Do Not Use All (Selected) Trees"/>

                                        <SeparatorMenuItem mnemonicParsing="false"/>
                                        <MenuItem fx:id="runMenuItem" mnemonicParsing="false" text="Run PhyloFusion">
                                            <accelerator>
                                                <KeyCodeCombination alt="UP" code="R" control="UP" meta="UP" shift="UP"
                                                                    shortcut="DOWN"/>
                                            </accelerator>
                                        </MenuItem>
                                    </items>
                                </Menu>

                                <Menu fx:id="layoutMenu" mnemonicParsing="false" text="Layout">
                                    <MenuItem fx:id="showAllMenuItem" mnemonicParsing="false"
                                              text="Show All (Selected) Trees">
                                        <accelerator>
                                            <KeyCodeCombination alt="UP" code="A" control="UP" meta="UP" shift="UP"
                                                                shortcut="DOWN"/>
                                        </accelerator>
                                    </MenuItem>
                                    <MenuItem fx:id="showNoneMenuItem" mnemonicParsing="false"
                                              text="Hide All (Selected) Trees">
                                        <accelerator>
                                            <KeyCodeCombination alt="UP" code="A" control="UP" meta="UP" shift="DOWN"
                                                                shortcut="DOWN"/>
                                        </accelerator>
                                    </MenuItem>
                                    <SeparatorMenuItem mnemonicParsing="false"/>
                                    <MenuItem fx:id="rotateLeftMenuItem" text="Rotate Left">
                                        <accelerator>
                                            <KeyCodeCombination alt="UP" code="LEFT" control="UP" meta="UP" shift="UP"
                                                                shortcut="DOWN"/>
                                        </accelerator>
                                    </MenuItem>
                                    <MenuItem fx:id="rotateRightMenuItem" text="Rotate Right">
                                        <accelerator>
                                            <KeyCodeCombination alt="UP" code="RIGHT" control="UP" meta="UP" shift="UP"
                                                                shortcut="DOWN"/>
                                        </accelerator>
                                    </MenuItem>
                                    <MenuItem fx:id="flipHorizontalMenuItem" text="Flip Horizontal">
                                        <accelerator>
                                            <KeyCodeCombination alt="UP" code="LEFT" control="UP" meta="UP" shift="DOWN"
                                                                shortcut="DOWN"/>
                                        </accelerator>
                                    </MenuItem>
                                    <MenuItem fx:id="flipVerticalMenuItem" text="Flip Vertical">
                                        <accelerator>
                                            <KeyCodeCombination alt="UP" code="RIGHT" control="UP" meta="UP"
                                                                shift="DOWN" shortcut="DOWN"/>
                                        </accelerator>
                                    </MenuItem>
                                    <SeparatorMenuItem mnemonicParsing="false"/>
                                    <CheckMenuItem fx:id="resizeModeCheckMenuItem" mnemonicParsing="false"
                                                   text="Resize Mode">
                                        <accelerator>
                                            <KeyCodeCombination alt="UP" code="R" control="UP" meta="DOWN" shift="UP"
                                                                shortcut="UP"/>
                                        </accelerator>
                                    </CheckMenuItem>
                                    <SeparatorMenuItem mnemonicParsing="false"/>
                                    <MenuItem fx:id="layoutLabelMenuItem" mnemonicParsing="false" text="Layout Labels">
                                        <accelerator>
                                            <KeyCodeCombination alt="UP" code="L" control="UP" meta="DOWN" shift="UP"
                                                                shortcut="UP"/>
                                        </accelerator>
                                    </MenuItem>
                                    <SeparatorMenuItem mnemonicParsing="false"/>
                                    <Menu mnemonicParsing="false" text="Draw Phylogeny">
                                        <MenuItem fx:id="layoutPhylogenyMenuItem" mnemonicParsing="false" text="Apply"/>
                                        <SeparatorMenuItem mnemonicParsing="false"/>
                                        <RadioMenuItem fx:id="rectangularLayoutMenuItem" mnemonicParsing="false"
                                                       text="Rectangular Layout"/>
                                        <RadioMenuItem fx:id="circularLayoutMenuItem" mnemonicParsing="false"
                                                       text="Circular Layout"/>
                                        <RadioMenuItem fx:id="radialLayoutMenuItem" mnemonicParsing="false"
                                                       text="Radial Layout"/>
                                        <SeparatorMenuItem mnemonicParsing="false"/>
                                        <RadioMenuItem fx:id="phylogramMenuItem" mnemonicParsing="false"
                                                       text="To-Scale Phylogram"/>
                                        <RadioMenuItem fx:id="cladogramEarlyMenuItem" mnemonicParsing="false"
                                                       text="Early-Branching Cladogram"/>
                                        <RadioMenuItem fx:id="cladogramLateMenuItem" mnemonicParsing="false"
                                                       text="Late-Branching Cladogram"/>
                                    </Menu>
                                </Menu>

                                <Menu mnemonicParsing="false" text="View">
                                    <items>
                                        <CheckMenuItem fx:id="useDarkThemeCheckMenuItem" mnemonicParsing="false"
                                                       text="Use Dark Theme"/>
                                        <SeparatorMenuItem mnemonicParsing="false"/>
                                        <MenuItem fx:id="increaseFontSizeMenuItem" text="Increase Font Size">
                                            <accelerator>
                                                <KeyCodeCombination alt="UP" code="ADD" control="UP" meta="UP"
                                                                    shift="UP" shortcut="DOWN"/>
                                            </accelerator>
                                        </MenuItem>
                                        <MenuItem fx:id="decreaseFontSizeMenuItem" text="Decrease Font Size">
                                            <accelerator>
                                                <KeyCodeCombination alt="UP" code="MINUS" control="UP" meta="UP"
                                                                    shift="UP" shortcut="DOWN"/>
                                            </accelerator>
                                        </MenuItem>
                                        <SeparatorMenuItem mnemonicParsing="false"/>
                                        <MenuItem fx:id="zoomInMenuItem" text="Zoom In">
                                            <accelerator>
                                                <KeyCodeCombination alt="UP" code="UP" control="UP" meta="UP" shift="UP"
                                                                    shortcut="DOWN"/>
                                            </accelerator>
                                        </MenuItem>
                                        <MenuItem fx:id="zoomOutMenuItem" text="Zoom Out">
                                            <accelerator>
                                                <KeyCodeCombination alt="UP" code="DOWN" control="UP" meta="UP"
                                                                    shift="UP" shortcut="DOWN"/>
                                            </accelerator>
                                        </MenuItem>
                                        <MenuItem fx:id="zoomToFitMenuItem" text="Zoom To Fit">
                                            <accelerator>
                                                <KeyCodeCombination alt="UP" code="PERIOD" control="UP" meta="UP"
                                                                    shift="UP" shortcut="DOWN"/>
                                            </accelerator>
                                        </MenuItem>
                                        <SeparatorMenuItem mnemonicParsing="false"/>
                                        <MenuItem fx:id="fullScreenMenuItem" mnemonicParsing="false"
                                                  text="Enter Full Screen">
                                            <accelerator>
                                                <KeyCodeCombination alt="UP" code="F" control="DOWN" meta="DOWN"
                                                                    shift="UP" shortcut="UP"/>
                                            </accelerator>
                                        </MenuItem>
                                    </items>
                                </Menu>
                                <Menu fx:id="windowMenu" mnemonicParsing="false" text="Window">
                                    <items>
                                        <MenuItem fx:id="setWindowSizeMenuItem" mnemonicParsing="false"
                                                  text="Set Window Size..."/>
                                        <SeparatorMenuItem mnemonicParsing="false"/>
                                    </items>
                                </Menu>
                                <Menu mnemonicParsing="false" text="Help">
                                    <items>
                                        <MenuItem fx:id="checkForUpdatesMenuItem" mnemonicParsing="false"
                                                  text="Check for Updates..."/>
                                        <SeparatorMenuItem mnemonicParsing="false"/>
                                        <MenuItem fx:id="aboutMenuItem" mnemonicParsing="false" text="About..."/>
                                        <SeparatorMenuItem mnemonicParsing="false"/>
                                        <CheckMenuItem fx:id="showHelpWindow" mnemonicParsing="false"
                                                       text="Help Window..."/>
                                    </items>
                                </Menu>
                            </menus>
                        </MenuBar>
                    </children>
                </VBox>
            </top>
            <bottom>
                <AnchorPane fx:id="bottomAnchorPane" BorderPane.alignment="CENTER">
                    <children>
                        <FlowPane fx:id="bottomFlowPane" alignment="CENTER_LEFT" hgap="2.0" maxHeight="-Infinity"
                                  minHeight="32.0" prefWrapLength="100.0" rowValignment="TOP" vgap="2.0"
                                  AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                            <padding>
                                <Insets bottom="5.0" left="10.0" right="60.0" top="5.0"/>
                            </padding>
                        </FlowPane>
                        <Label fx:id="memoryUsageLabel" text="Memory" AnchorPane.bottomAnchor="10.0"
                               AnchorPane.rightAnchor="16.0"/>
                    </children>
                </AnchorPane>
            </bottom>

        </BorderPane>
    </children>
</AnchorPane>
